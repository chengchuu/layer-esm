{
  "presets": [
    [
      "@babel/preset-env",
      {
        "targets": {
          "browsers": [
            "last 2 Chrome versions",
            "last 2 Edge versions",
            "last 2 Firefox versions",
            "last 2 Safari versions",
            "iOS >= 15",
            "and_chr >= 100"
          ]
        },
        "exclude": ["@babel/plugin-transform-typeof-symbol"]
      }
    ],
    "@babel/typescript"
  ],
  "plugins": [],
  "sourceType": "unambiguous"
}
