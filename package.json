{
  "name": "layer-esm",
  "version": "1.0.13",
  "description": "Modern ESM Layer Library for Web Popups and Dialogs",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "typings": "./dist/index.d.ts",
  "types": "./dist/index.d.ts",
  "mainEntryPointFilePath": "./dist/index.d.ts",
  "directories": {
    "lib": "./dist"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "webpack-dev-server --config ./scripts/webpack.config.dev.cjs",
    "dev:open": "webpack-dev-server --config ./scripts/webpack.config.dev.cjs --open",
    "build": "cross-env SCRIPTS_NPM_PACKAGE_DEBUG=close SCRIPTS_NPM_PACKAGE_VERSION=$npm_package_version rollup --config ./scripts/rollup.config.mjs",
    "build:debug": "cross-env SCRIPTS_NPM_PACKAGE_DEBUG=open SCRIPTS_NPM_PACKAGE_VERSION=$npm_package_version rollup --config ./scripts/rollup.config.mjs",
    "build:dev": "webpack --config ./scripts/webpack.config.dev.cjs",
    "build:site": "cross-env GITHUB_PAGES=true webpack --mode production --config ./scripts/webpack.config.dev.cjs",
    "pretest": "npm run build",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --ext '.js,.ts,.tsx,.cjs,.mjs' ./examples ./scripts ./site ./src ./test ./project.config.cjs",
    "format:check": "prettier --check README.md package.json tsconfig.json project.config.cjs .github/workflows/pages.yml examples/index.html examples/index.ts site scripts/build-pages.cjs scripts/preview-pages.cjs scripts/project-config-utils.cjs scripts/validate-pwa.cjs scripts/validate-seo.cjs scripts/webpack.config.dev.cjs test/pwa.test.js test/seo.test.js test/service-worker.test.js test/theme.test.js",
    "docs": "typedoc --out ./docs/api --readme ./README.md --excludeProtected --excludePrivate --excludeInternal --hideGenerator && npm run build:site && node ./scripts/build-pages.cjs && npm run seo:validate && npm run pwa:validate",
    "seo:validate": "node ./scripts/validate-seo.cjs",
    "pwa:validate": "node ./scripts/validate-pwa.cjs",
    "pwa:preview": "npm run docs && node ./scripts/preview-pages.cjs",
    "lint:fix": "eslint --ext '.js,.ts,.tsx,.cjs,.mjs' --fix ./examples ./scripts ./src ./test",
    "preview": "npm run typecheck && npm run lint && npm run build && npm run test && npm run docs && npm run format:check",
    "release": "npm run preview && cross-env SCRIPTS_NPM_PACKAGE_VERSION=$npm_package_version node ./scripts/release.cjs",
    "release:win": "bash scripts/env-win.sh && npm i --registry=https://registry.npmjs.org && npm run release"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chengchuu/layer-esm.git"
  },
  "keywords": [
    "dialog",
    "popup",
    "modal",
    "layer",
    "typescript",
    "esm"
  ],
  "author": {
    "name": "Cheng",
    "email": "mazeyqian@gmail.com",
    "url": "https://github.com/chengchuu"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/chengchuu/layer-esm/issues"
  },
  "homepage": "https://chengchuu.github.io/layer-esm/",
  "devDependencies": {
    "@babel/core": "^7.23.2",
    "@babel/plugin-transform-class-properties": "^7.22.5",
    "@babel/plugin-transform-object-rest-spread": "^7.22.15",
    "@babel/plugin-transform-runtime": "^7.23.2",
    "@babel/preset-env": "^7.23.2",
    "@babel/preset-typescript": "^7.23.2",
    "@babel/runtime": "^7.23.2",
    "@babel/runtime-corejs3": "^7.23.2",
    "@commitlint/cli": "^17.8.1",
    "@commitlint/config-conventional": "^17.8.1",
    "@rollup/plugin-babel": "^6.0.3",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/node": "^25.0.9",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "bootstrap": "5.3.8",
    "clean-webpack-plugin": "^4.0.0",
    "core-js": "^3.33.2",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "date-fns": "^2.30.0",
    "eslint": "^8.54.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-standard": "^4.1.0",
    "execa": "^5.1.1",
    "html-webpack-plugin": "^5.5.3",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^14.0.1",
    "markdown-toc": "^1.2.0",
    "mini-css-extract-plugin": "^2.9.2",
    "prettier": "^2.8.8",
    "prettier-eslint-cli": "^8.0.1",
    "rollup": "^3.29.4",
    "rollup-plugin-cleaner": "^1.0.0",
    "rollup-plugin-commonjs": "^10.1.0",
    "rollup-plugin-copy": "^3.4.0",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-node-resolve": "^5.2.0",
    "rollup-plugin-typescript2": "^0.34.1",
    "ts-loader": "^9.4.4",
    "tslib": "^2.6.2",
    "typedoc": "^0.25.4",
    "typescript": "5.3.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "lint-staged"
    }
  },
  "dependencies": {
    "mazey": "^4.11.1"
  }
}
